# Database connection
ENVIRONMENT=development
AUTO_CREATE_TABLES=true
SKIP_ALREADY_INGESTED=true
ALLOW_INSECURE_EMAIL_AUTH=true
ENABLE_API_DOCS=true
FORCE_HTTPS=false
TRUSTED_HOSTS=localhost,127.0.0.1
DATABASE_HOST=localhost
DB_USERNAME=postgres
DB_PASSWORD=your_db_password_here
DB_PORT=5432
DB_NAME=postgres
DB_SSLMODE=require
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE_SECONDS=1800

# Logging
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/app.log
LOG_TO_CONSOLE=true
REQUEST_ID_HEADER=X-Request-ID
MAX_QUERY_IMAGE_BYTES=10485760
MAX_INGESTION_IMAGE_BYTES=26214400

# Job execution (production must use celery with a durable Redis broker)
TASK_QUEUE_MODE=background
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Supabase Storage
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_STORAGE_BUCKET=images

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=face_embeddings

# JWT
SECRET_KEY=your_secret_key_here
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Frontend / backend
BACKEND_URL=http://127.0.0.1:8000
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8501,http://127.0.0.1:8501

# Google Picker
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_API_KEY=your_google_api_key
